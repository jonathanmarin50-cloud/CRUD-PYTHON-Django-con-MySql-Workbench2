# CONFIGURACIÓN DE BASE DE DATOS SUPABASE
# Copia este archivo como '.env' e ingresa tus credenciales reales.
# NO subas el archivo '.env' a GitHub.

# Estos datos los obtienes en Supabase -> Project Settings -> Database
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_HOST=db.xxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432

# URL de conexión directa (opcional, usada por servicios como Render)
DATABASE_URL=postgres://postgres:tu_contraseña@db.xxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# Seguridad de Django
SECRET_KEY=django-insecure-pedidos-crud-secret-key-2024
DEBUG=True
